{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "BusinessCloud API (.NET 10)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/BusinessCloud.Api/bin/Debug/net10.0/BusinessCloud.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/BusinessCloud.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            },
            "console": "integratedTerminal",
            "logging": {
                "moduleLoad": false
            }
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
